# Turso Database (SQLite na nuvem)
# Crie grátis em: https://turso.tech
# turso db create melfit
# turso db tokens create melfit
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Secret para proteger o cron job (gere um valor aleatório)
CRON_SECRET=your-random-secret-here

# Login do site atacado (para scraping autenticado)
ATACADO_EMAIL=seu-email@exemplo.com
ATACADO_PASSWORD=sua-senha
