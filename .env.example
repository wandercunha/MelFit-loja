# ══════════════════════════════════════════════════════════════
# VARIAVEIS OBRIGATORIAS (sem elas o login e APIs nao funcionam)
# ══════════════════════════════════════════════════════════════

# Hash SHA-256 da senha admin
# Gere com: node -e "console.log(require('crypto').createHash('sha256').update('SUA_SENHA').digest('hex'))"
# Ou rode: npm run admin:reset -- sua-senha
ADMIN_PASSWORD_HASH=

# Secret para proteger as APIs (gere um valor aleatorio)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=

# ══════════════════════════════════════════════════════════════
# OPCIONAIS
# ══════════════════════════════════════════════════════════════

# Turso Database (SQLite na nuvem - necessario para Vercel)
# Crie gratis em: https://turso.tech
# turso db create melfit && turso db tokens create melfit
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Secret para cron jobs da Vercel (gerado automaticamente pela Vercel)
CRON_SECRET=

# Scraping — delay entre requests em ms (padrao: 5000)
SCRAPE_DELAY=5000

# Login do atacado (opcional — usado pelo scraper para tentar acessar paginas de produto)
ATACADO_EMAIL=
ATACADO_PASSWORD=

# Todas as outras configuracoes (margens, taxas, WhatsApp)
# sao gerenciadas pelo painel Admin e salvas no banco Turso.
