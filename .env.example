# Turso Database (SQLite na nuvem - somente para deploy na Vercel)
# Crie gratis em: https://turso.tech
# turso db create melfit
# turso db tokens create melfit
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Secret para proteger o cron job (gere um valor aleatorio)
CRON_SECRET=your-random-secret-here

# Todas as outras configuracoes (margens, taxas, WhatsApp, login atacado)
# sao gerenciadas pelo painel Admin e salvas no localStorage do navegador.
